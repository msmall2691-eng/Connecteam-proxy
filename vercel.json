{
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/connecteam/:path*",
      "destination": "/api/connecteam?path=:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/visits?action=generate-recurring&weeks=8",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/google?action=calendar-sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/auto-turnovers?action=scan&days=30",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/reminders?action=send",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/visits?action=follow-up",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/visits?action=review-request",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/campaigns?action=run-sequences",
      "schedule": "0 12 * * *"
    }
  ]
}
