{
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/connecteam/:path*",
      "destination": "/api/connecteam?path=:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/visits?action=generate-recurring&weeks=8",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/auto-turnovers?action=scan&days=30",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/reminders?action=send",
      "schedule": "0 18 * * *"
    }
  ]
}
